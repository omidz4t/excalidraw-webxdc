{
  "private": true,
  "name": "excalidraw-monorepo",
  "version": "1.0.2",
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "excalidraw-app",
    "packages/*"
  ],
  "devDependencies": {
    "@babel/preset-env": "7.26.9",
    "@excalidraw/eslint-config": "1.0.3",
    "@excalidraw/prettier-config": "1.0.2",
    "@types/chai": "4.3.0",
    "@types/jest": "27.4.0",
    "@types/lodash.throttle": "4.1.7",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@types/socket.io-client": "3.0.0",
    "@vitejs/plugin-react": "3.1.0",
    "@vitest/coverage-v8": "3.0.7",
    "@vitest/ui": "2.0.5",
    "chai": "4.3.6",
    "cross-env": "7.0.3",
    "dotenv": "16.0.1",
    "eslint-config-prettier": "8.5.0",
    "eslint-config-react-app": "7.0.1",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-prettier": "3.3.1",
    "http-server": "14.1.1",
    "jsdom": "22.1.0",
    "lint-staged": "12.3.7",
    "pepjs": "0.5.3",
    "prettier": "2.6.2",
    "purgecss": "8.0.0",
    "rewire": "6.0.0",
    "rimraf": "^5.0.0",
    "typescript": "5.9.3",
    "vite": "5.0.12",
    "vite-plugin-checker": "0.7.2",
    "vite-plugin-ejs": "1.7.0",
    "vite-plugin-pwa": "0.21.1",
    "vite-plugin-svgr": "4.2.0",
    "vitest": "3.0.6",
    "vitest-canvas-mock": "0.3.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "semantic-release": "^25.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "homepage": ".",
  "prettier": "@excalidraw/prettier-config",
  "scripts": {
    "build-node": "node ./scripts/build-node.js",
    "build:app": "bun run --cwd ./excalidraw-app build:app",
    "build:common": "bun run --cwd ./packages/common build:esm",
    "build:element": "bun run --cwd ./packages/element build:esm",
    "build:excalidraw": "bun run --cwd ./packages/excalidraw build:esm",
    "build:math": "bun run --cwd ./packages/math build:esm",
    "build:fractional-indexing": "bun run --cwd ./packages/fractional-indexing build:esm",
    "build:laser-pointer": "bun run --cwd ./packages/laser-pointer build:esm",
    "build:packages": "bun run build:common && bun run build:fractional-indexing && bun run build:laser-pointer && bun run build:math && bun run build:element && bun run build:excalidraw",
    "build:version": "bun run --cwd ./excalidraw-app build:version",
    "build": "bun run --cwd ./excalidraw-app build",
    "build:preview": "bun run --cwd ./excalidraw-app build:preview",
    "build:webxdc": "bun run --cwd ./excalidraw-app build:webxdc",
    "package:release": "bash scripts/package-release.sh",
    "dev:webxdc": "bun run --cwd ./excalidraw-app dev:webxdc",
    "start": "bun run --cwd ./excalidraw-app start",
    "start:production": "bun run --cwd ./excalidraw-app start:production",
    "test:all": "bun run test:typecheck && bun run test:code && bun run test:other && bun run test:app -- --watch=false",
    "test:app": "vitest",
    "test:code": "eslint --max-warnings=0 --ext .js,.ts,.tsx .",
    "test:other": "bun run prettier -- --list-different",
    "test:typecheck": "tsc",
    "test:update": "bun run test:app -- --update --watch=false",
    "test": "bun run test:app",
    "test:coverage": "vitest --coverage",
    "test:coverage:watch": "vitest --coverage --watch",
    "test:ui": "bun run test -- --ui --coverage.enabled=true",
    "fix:code": "bun run test:code -- --fix",
    "fix:other": "bun run prettier -- --write",
    "fix": "bun run fix:other && bun run fix:code",
    "prettier": "prettier \"**/*.{css,scss,json,md,html,yml}\" --ignore-path=.eslintignore",
    "rm:build": "rimraf --glob excalidraw-app/build excalidraw-app/dist excalidraw-app/dev-dist packages/*/dist packages/*/build",
    "rm:node_modules": "rimraf --glob node_modules excalidraw-app/node_modules packages/*/node_modules",
    "clean-install": "bun run rm:node_modules && bun install"
  },
  "overrides": {
    "strip-ansi": "6.0.1"
  }
}
